# Backend runtime
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/hicms

# Auth / encryption secrets - replace with strong unique values
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
PORTAL_PASSWORD_SECRET=replace-with-a-long-random-portal-secret
ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d

# App / CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_MAX=100

# Advanced notification email delivery
# These SMTP values are required for actual email delivery. Without them, the
# Advanced Notifications panel can save an email, but the backend will skip mail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=your-smtp-username@example.com
SMTP_PASS=your-smtp-password-or-app-password
SMTP_HELO_HOST=localhost
MAIL_FROM=Malavia Claims <your-smtp-username@example.com>


