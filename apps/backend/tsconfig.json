{
  "extends": "../../packages/ts-config/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "baseUrl": "./src",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts", "src/**/__tests__/*", "src/tests/**/*"]
}
