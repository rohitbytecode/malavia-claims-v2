{
  "name": "desktop",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('assets', 'dist/assets', {recursive: true})\" && node -e \"require('fs').copyFileSync('preload.cjs', 'dist/preload.cjs')\"",
    "package": "pnpm build && electron-builder --win --x64",
    "lint": "echo \"(todo)\""
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.9.3",
    "@types/node": "^25.8.0"
  },
  "build": {
    "appId": "com.claimmanagement.desktop",
    "productName": "Claim Management",
    "icon": "assets/logo.ico",
    "asar": true,
    "asarUnpack": [
      "assets/**/*",
      "preload.cjs"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "assets/**/*",
      "preload.cjs"
    ],
    "win": {
      "icon": "assets/logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "../backend/dist/server.bundle.cjs",
        "to": "apps/backend/dist/server.bundle.cjs"
      },
      {
        "from": "../backend/cert",
        "to": "apps/backend/cert"
      },
      {
        "from": "../backend/.env",
        "to": "apps/backend/.env"
      },
      {
        "from": "../frontend/dist",
        "to": "apps/frontend/dist"
      },
      {
        "from": "../backend/node_modules",
        "to": "apps/backend/node_modules",
        "filter": [
          "!**/backend/**",
          "!**/@types/**",
          "!**/mongodb-memory-server/**",
          "!**/vitest/**",
          "!**/eslint/**",
          "!**/@vitest/**",
          "!**/typescript/**",
          "!**/esbuild/**",
          "!**/tsx/**",
          "!**/nodemon/**",
          "!**/prettier/**",
          "!**/supertest/**",
          "!**/tsc-alias/**",
          "!**/typescript-eslint/**",
          "!**/pm2/**"
        ]
      }
    ]
  }
}
